# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# Ollama
OLLAMA_BASE_URL="https://your-ollama-host.example.com"
CHAT_MODEL="llama3"
EMBED_MODEL="nomic-embed-text"

# Server
PORT=5000
NODE_ENV="production"
AUTH_SECRET="replace-with-at-least-32-random-characters"
CORS_ORIGINS="https://your-frontend-domain.example.com"
TRUST_PROXY=true

# RAG & Datafiles
DATAFILES_PATH="./datafiles"
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_CHUNKS=5
